            "icon": "shopify://shop_images/freepik__background__68644_1.png",
            "accordion_title": "Regenerative Stewardship",
            "accordion_content": "<p>We protect and restore the land that feeds us by supporting soil health, preserving biodiversity, and farming practices that give more than they take, ensuring the Andes can nourish generations to come.</p>"
          }
        },
        "accordion_item_QEF3QU": {
