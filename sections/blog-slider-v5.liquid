{% assign section_id = section.id %}
{% assign cleaned_id = section_id | replace: '_', '-' | replace: '--', '-' | replace: '__', '-' %}

{% style %}
  .blog-section-{{ cleaned_id }} {
    display: block;
    width: 100%;
    justify-self: anchor-center;
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
  }

  .blog-section__container-{{ cleaned_id }} {
    max-width: 80%;
    margin: 0 auto;
    padding: 0 {{ section.settings.container_padding }}px;
  }

  .blog-section__header-{{ cleaned_id }} {
    text-align: {{ section.settings.heading_alignment }};
    margin-bottom: {{ section.settings.header_margin_bottom }}px;
  }

  .blog-section__eyebrow-{{ cleaned_id }} {
    display: inline-block;
    color: {{ section.settings.eyebrow_color }};
    font-size: 12px;
    font-weight: 600;
    text-transform: capitalize;
    letter-spacing: 2px;
    margin-bottom: 12px;
  }

  .blog-section__heading-{{ cleaned_id }} {
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    line-height: 1.2;
    margin: 0 0 12px 0;
  }

  .blog-section__subheading-{{ cleaned_id }} {
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.subheading_size }}px;
    margin: 0;
    opacity: 0.85;
  }

  /* GRID LAYOUT */
  .blog-section__grid-{{ cleaned_id }} {
    display: grid;
    grid-template-columns: repeat({{ section.settings.grid_columns }}, 1fr);
    gap: {{ section.settings.card_gap }}px;
  }

  /* SLIDER LAYOUT */
  .blog-section__wrapper-{{ cleaned_id }} {
    position: relative;
    overflow: hidden;
  }

  .blog-section__track-{{ cleaned_id }} {
    display: flex;
    gap: {{ section.settings.card_gap }}px;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .blog-section__card-{{ cleaned_id }} {
    background-color: {{ section.settings.card_background }};
    border-radius: {{ section.settings.card_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(255, 255, 255, 0.02);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    border: {{ section.settings.card_border_width }}px solid {{ section.settings.card_border_color }};
    {% if section.settings.layout_mode == 'slider' %}
    flex: 0 0 calc((100% - {{ section.settings.card_gap | times: 2 }}px) / 3);
    {% endif %}
  }

  .blog-section__card-{{ cleaned_id }}:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
  }

  .blog-section__image-wrapper-{{ cleaned_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ section.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .blog-section__image-{{ cleaned_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .blog-section__card-{{ cleaned_id }}:hover .blog-section__image-{{ cleaned_id }} {
    transform: scale(1.05);
  }

  .blog-section__image-placeholder-{{ cleaned_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f8f8f8;
  }

  .blog-section__image-placeholder-{{ cleaned_id }} svg {
    width: 80px;
    height: 80px;
    opacity: 0.3;
  }

  .blog-section__content-{{ cleaned_id }} {
    padding: {{ section.settings.card_padding }}px;
  }

  .blog-section__date-{{ cleaned_id }} {
    color: {{ section.settings.date_color }};
    font-size: 12px;
    font-weight: 500;
    text-transform: capitalize;
    letter-spacing: 1px;
    margin-bottom: 10px;
    opacity: 0.7;
  }

  .blog-section__title-{{ cleaned_id }} {
    color: {{ section.settings.card_title_color }};
    font-size: {{ section.settings.card_title_size }}px;
    font-weight: {{ section.settings.card_title_weight }};
    text-transform: capitalize;
    line-height: {{ section.settings.card_title_line_height }};
    margin: 0 0 {{ section.settings.card_title_margin }}px 0;
    transition: color 0.3s ease;
  }

  .blog-section__title-link-{{ cleaned_id }} {
    color: inherit;
    text-decoration: none;
  }

  .blog-section__card-{{ cleaned_id }}:hover .blog-section__title-{{ cleaned_id }} {
    color: {{ section.settings.accent_color }};
  }

  .blog-section__excerpt-{{ cleaned_id }} {
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.excerpt_size }}px;
    line-height: 1.6;
    margin-bottom: {{ section.settings.excerpt_margin }}px;
    opacity: 0.85;
  }

  /* Read More Button */
  .blog-section__button-{{ cleaned_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: {{ section.settings.button_padding_y }}px {{ section.settings.button_padding_x }}px;
    background-color: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text_color }};
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: {{ section.settings.button_font_weight }};
    text-decoration: none;
    border: {{ section.settings.button_border_width }}px solid {{ section.settings.button_border_color }};
    border-radius: {{ section.settings.button_border_radius }}px;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .blog-section__button-{{ cleaned_id }}:hover {
    background-color: {{ section.settings.button_hover_bg }};
    color: {{ section.settings.button_hover_text }};
    border-color: {{ section.settings.button_hover_border }};
    transform: translateX(4px);
  }

  .blog-section__button-icon-{{ cleaned_id }} {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  .blog-section__button-{{ cleaned_id }}:hover .blog-section__button-icon-{{ cleaned_id }} {
    transform: translateX(4px);
  }

  /* Navigation Controls - Only for Slider */
  .blog-section__controls-{{ cleaned_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-top: {{ section.settings.controls_margin_top }}px;
  }

  .blog-section__nav-{{ cleaned_id }} {
    width: {{ section.settings.nav_button_size }}px;
    height: {{ section.settings.nav_button_size }}px;
    border-radius: {{ section.settings.nav_button_radius }}px;
    background-color: {{ section.settings.nav_bg }};
    color: {{ section.settings.nav_color }};
    border: {{ section.settings.nav_border_width }}px solid {{ section.settings.nav_border_color }};
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .blog-section__nav-{{ cleaned_id }}:hover {
    background-color: {{ section.settings.nav_hover_bg }};
    color: {{ section.settings.nav_hover_color }};
    border-color: {{ section.settings.nav_hover_bg }};
    transform: scale(1.1);
  }

  .blog-section__nav-{{ cleaned_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
    transform: none;
  }

  .blog-section__nav-{{ cleaned_id }} svg {
    width: 20px;
    height: 20px;
  }

  .blog-section__dots-{{ cleaned_id }} {
    display: flex;
    gap: 8px;
  }

  .blog-section__dot-{{ cleaned_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ section.settings.dot_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
    opacity: 0.4;
  }

  .blog-section__dot-{{ cleaned_id }}.active {
    background-color: {{ section.settings.dot_active_color }};
    opacity: 1;
    width: 24px;
    border-radius: 4px;
  }

  .blog-section__empty-{{ cleaned_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ section.settings.text_color }};
  }

  /* Responsive Grid */
  {% if section.settings.layout_mode == 'grid' %}
  @media screen and (max-width: 1200px) {
    .blog-section__grid-{{ cleaned_id }} {
      grid-template-columns: repeat({{ section.settings.grid_columns | at_most: 3 }}, 1fr);
    }
  }
  {% endif %}

  @media screen and (max-width: 989px) {
    {% if section.settings.layout_mode == 'grid' %}
    .blog-section__grid-{{ cleaned_id }} {
      grid-template-columns: repeat({{ section.settings.grid_columns_tablet }}, 1fr);
    }
    {% else %}
    .blog-section__card-{{ cleaned_id }} {
      flex: 0 0 calc((100% - {{ section.settings.card_gap }}px) / 2);
    }
    {% endif %}

    .blog-section__heading-{{ cleaned_id }} {
      font-size: calc({{ section.settings.heading_size }}px * 0.85);
    }

    .blog-section__content-{{ cleaned_id }} {
      padding: {{ section.settings.card_padding | times: 0.85 | round }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .blog-section-{{ cleaned_id }} {
      padding: {{ section.settings.padding_top | times: 0.7 | round }}px 16px {{ section.settings.padding_bottom | times: 0.7 | round }}px;
    }

    {% if section.settings.layout_mode == 'grid' %}
    .blog-section__grid-{{ cleaned_id }} {
      grid-template-columns: repeat({{ section.settings.grid_columns_mobile }}, 1fr);
    }
    {% else %}
    .blog-section__card-{{ cleaned_id }} {
      flex: 0 0 100%;
    }
    {% endif %}

    .blog-section__heading-{{ cleaned_id }} {
      font-size: calc({{ section.settings.heading_size }}px * 0.7);
    }

    .blog-section__title-{{ cleaned_id }} {
      font-size: calc({{ section.settings.card_title_size }}px * 0.9);
    }

    .blog-section__content-{{ cleaned_id }} {
      padding: {{ section.settings.card_padding | times: 0.75 | round }}px;
    }
  }
{% endstyle %}

<div class="blog-section-{{ cleaned_id }}" data-section-id="{{ cleaned_id }}" data-layout="{{ section.settings.layout_mode }}" data-card-gap="{{ section.settings.card_gap }}" {{ section.shopify_attributes }}>
  <div class="blog-section__container-{{ cleaned_id }}">
    {% if section.settings.eyebrow != blank
      or section.settings.heading != blank
      or section.settings.subheading != blank
    %}
      <div class="blog-section__header-{{ cleaned_id }}">
        {% if section.settings.eyebrow != blank %}
          <span class="blog-section__eyebrow-{{ cleaned_id }}">{{ section.settings.eyebrow }}</span>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="blog-section__heading-{{ cleaned_id }}">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class="blog-section__subheading-{{ cleaned_id }}">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if section.settings.blog != blank %}
      {% assign articles = section.settings.blog.articles %}
      {% assign max_posts = section.settings.max_posts %}
      {% assign article_count = articles.size | at_most: max_posts %}

      {% if article_count > 0 %}
        {% if section.settings.layout_mode == 'grid' %}
          {% comment %} GRID LAYOUT {% endcomment %}
          <div class="blog-section__grid-{{ cleaned_id }}">
            {% for article in articles limit: max_posts %}
              {% render 'blog-card',
                article: article,
                cleaned_id: cleaned_id,
                section: section
              %}
            {% endfor %}
          </div>
        {% else %}
          {% comment %} SLIDER LAYOUT {% endcomment %}
          <div class="blog-section__wrapper-{{ cleaned_id }}">
            <div class="blog-section__track-{{ cleaned_id }}" data-slider-track>
              {% for article in articles limit: max_posts %}
                {% render 'blog-card',
                  article: article,
                  cleaned_id: cleaned_id,
                  section: section
                %}
              {% endfor %}
            </div>
          </div>

          {% if article_count > 3 %}
            <div class="blog-section__controls-{{ cleaned_id }}">
              <button class="blog-section__nav-{{ cleaned_id }}" data-slider-prev aria-label="Previous">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="15 18 9 12 15 6"></polyline>
                </svg>
              </button>
              <div class="blog-section__dots-{{ cleaned_id }}" data-slider-dots></div>
              <button class="blog-section__nav-{{ cleaned_id }}" data-slider-next aria-label="Next">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
              </button>
            </div>
          {% endif %}
        {% endif %}
      {% else %}
        <div class="blog-section__empty-{{ cleaned_id }}">
          <p>No articles found in this blog.</p>
        </div>
      {% endif %}
    {% else %}
      <div class="blog-section__empty-{{ cleaned_id }}">
        <p>Please select a blog to display articles.</p>
      </div>
    {% endif %}
  </div>
</div>

{% if section.settings.layout_mode == 'slider' %}
<script>
  document.addEventListener('DOMContentLoaded', function() {
    class BlogSlider {
      constructor(element) {
        this.element = element;
        this.sectionId = element.dataset.sectionId;
        this.current = 0;
        this.perView = 3;
        this.track = element.querySelector('[data-slider-track]');
        this.prev = element.querySelector('[data-slider-prev]');
        this.next = element.querySelector('[data-slider-next]');
        this.dotsWrap = element.querySelector('[data-slider-dots]');

        if (!this.track) return;

        this.cards = Array.from(this.track.children);
        this.total = this.cards.length;

        if (this.total === 0) return;

        this.updatePerView();
        this.createDots();
        this.setupEvents();
        this.update();

        window.addEventListener('resize', () => {
          this.updatePerView();
          this.createDots();
          this.current = Math.min(this.current, this.maxSlide);
          this.update();
        });
      }

      updatePerView() {
        if (window.innerWidth <= 749) this.perView = 1;
        else if (window.innerWidth <= 989) this.perView = 2;
        else this.perView = 3;
        
        this.perView = Math.min(this.perView, this.total);
        this.maxSlide = Math.max(0, this.total - this.perView);
      }

      createDots() {
        if (!this.dotsWrap) return;
        this.dotsWrap.innerHTML = '';
        
        if (this.maxSlide <= 0) return;
        
        for (let i = 0; i <= this.maxSlide; i++) {
          const dot = document.createElement('button');
          dot.className = 'blog-section__dot-' + this.sectionId;
          dot.setAttribute('aria-label', 'Slide ' + (i + 1));
          dot.onclick = () => this.goTo(i);
          this.dotsWrap.appendChild(dot);
        }
        this.dots = Array.from(this.dotsWrap.children);
      }

      setupEvents() {
        if (this.prev) this.prev.onclick = () => this.goTo(this.current - 1);
        if (this.next) this.next.onclick = () => this.goTo(this.current + 1);

        let startX = 0;
        this.track.addEventListener('touchstart', e => { 
          startX = e.touches[0].clientX; 
        }, {passive: true});
        
        this.track.addEventListener('touchend', e => {
          const diff = startX - e.changedTouches[0].clientX;
          if (Math.abs(diff) > 50) this.goTo(this.current + (diff > 0 ? 1 : -1));
        }, {passive: true});
      }

      goTo(i) {
        if (this.maxSlide <= 0) return;
        this.current = Math.max(0, Math.min(i, this.maxSlide));
        this.update();
      }

      update() {
        const gap = parseInt(this.element.dataset.cardGap);
        const cardW = this.cards[0] ? this.cards[0].offsetWidth : 0;
        
        if (this.maxSlide > 0) {
          this.track.style.transform = 'translateX(-' + (this.current * (cardW + gap)) + 'px)';
        } else {
          this.track.style.transform = 'translateX(0)';
        }

        if (this.dots) {
          this.dots.forEach((d, i) => d.classList.toggle('active', i === this.current));
        }
        
        if (this.prev) {
          this.prev.disabled = this.current === 0 || this.maxSlide <= 0;
          this.prev.style.opacity = this.prev.disabled ? '0.3' : '1';
        }
        
        if (this.next) {
          this.next.disabled = this.current >= this.maxSlide || this.maxSlide <= 0;
          this.next.style.opacity = this.next.disabled ? '0.3' : '1';
        }
      }
    }

    // Initialize sliders only for slider layout
    const blogSliders = document.querySelectorAll('[data-layout="slider"]');
    blogSliders.forEach(element => {
      if (element.querySelector('[data-slider-track]')) {
        new BlogSlider(element);
      }
    });
  });
</script>
{% endif %}

{% schema %}
{
  "name": "Blog Section v5",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "━━━ LAYOUT MODE ━━━" },
    {
      "type": "select",
      "id": "layout_mode",
      "label": "Display mode",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "slider", "label": "Slider" }
      ],
      "default": "grid"
    },
    
    { "type": "header", "content": "━━━ BLOG ━━━" },
    { "type": "blog", "id": "blog", "label": "Select blog" },
    { "type": "range", "id": "max_posts", "min": 3, "max": 12, "step": 1, "label": "Max posts", "default": 6 },

    { "type": "header", "content": "━━━ GRID SETTINGS ━━━" },
    {
      "type": "range",
      "id": "grid_columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Desktop columns",
      "default": 3,
      "info": "Number of columns on desktop"
    },
    {
      "type": "range",
      "id": "grid_columns_tablet",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Tablet columns",
      "default": 2
    },
    {
      "type": "range",
      "id": "grid_columns_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Mobile columns",
      "default": 1
    },

    { "type": "header", "content": "━━━ SPACING ━━━" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    },
    {
      "type": "range",
      "id": "container_padding",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "label": "Side padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "header_margin_bottom",
      "min": 20,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Header margin",
      "default": 40
    },

    { "type": "header", "content": "━━━ HEADER ━━━" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Latest Recipes" },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover our newest culinary creations"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 56,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 36
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 14,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Subheading size",
      "default": 16
    },

    { "type": "header", "content": "━━━ CARDS ━━━" },
    {
      "type": "range",
      "id": "card_gap",
      "min": 12,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Gap between cards",
      "default": 24
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 12
    },
    {
      "type": "range",
      "id": "card_border_width",
      "min": 0,
      "max": 2,
      "step": 1,
      "unit": "px",
      "label": "Border width",
      "default": 0
    },
    {
      "type": "range",
      "id": "card_padding",
      "min": 16,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Content padding",
      "default": 24
    },
    {
      "type": "range",
      "id": "image_aspect_ratio",
      "min": 50,
      "max": 100,
      "step": 5,
      "label": "Image ratio (%)",
      "default": 65,
      "info": "66 = 3:2, 75 = 4:3, 56 = 16:9"
    },

    { "type": "header", "content": "━━━ CARD TITLE ━━━" },
    {
      "type": "range",
      "id": "card_title_size",
      "min": 16,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Title size",
      "default": 20
    },
    {
      "type": "select",
      "id": "card_title_weight",
      "label": "Title weight",
      "options": [
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "card_title_line_height",
      "min": 1.1,
      "max": 1.5,
      "step": 0.1,
      "label": "Line height",
      "default": 1.3
    },
    {
      "type": "range",
      "id": "card_title_margin",
      "min": 8,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Title margin",
      "default": 12
    },

    { "type": "header", "content": "━━━ EXCERPT ━━━" },
    { "type": "checkbox", "id": "show_excerpt", "label": "Show excerpt", "default": true },
    {
      "type": "range",
      "id": "excerpt_size",
      "min": 13,
      "max": 16,
      "step": 1,
