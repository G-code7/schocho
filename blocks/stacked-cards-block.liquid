      "id": "mobile_title_font_size",
      "label": "Tamaño título mobile",
      "min": 16,
      "max": 56,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "mobile_description_font_size",
      "label": "Tamaño descripción mobile",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },

    {
      "type": "header",
      "content": "Animación de entrada"
    },
    {
      "type": "range",
      "id": "animation_duration",
      "label": "Duración (ms)",
      "min": 200,
      "max": 1200,
      "step": 50,
      "unit": "ms",
      "default": 700
    },
    {
      "type": "range",
      "id": "animation_delay",
      "label": "Retardo (ms)",
