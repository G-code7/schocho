      "type": "range",
      "id": "animation_offset",
      "label": "Desplazamiento inicial (Y)",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Tarjeta apilada"
    }
  ]
}
{% endschema %}
